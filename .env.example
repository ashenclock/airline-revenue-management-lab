# === Kaggle API credentials (optional if using kagglehub interactive login) ===
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# === Memory constraints ===
MEMORY_LIMIT_GB=5.0
CHUNK_SIZE=100000

# === Parallelism ===
N_JOBS=2

# === Random seed ===
RANDOM_SEED=42

# === Logging ===
LOG_LEVEL=INFO
